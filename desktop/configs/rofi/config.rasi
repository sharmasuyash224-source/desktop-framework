configuration {
    modi: "drun";
    show-icons: true;

    display-drun: "Applications";

    font: "JetBrainsMono Nerd Font 12";

    icon-theme: "Papirus-Dark";

    terminal: "kitty";

    drun-display-format: "{icon}  {name}";

    hover-select: true;

    disable-history: false;

    sort: true;
}

@theme "theme"
